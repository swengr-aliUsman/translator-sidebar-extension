{
  "manifest_version": 3,
  "name": "Translate Sidebar",
  "version": "1.0.0",
  "description": "Select page text and translate it in a sidebar view similar to Google Translate.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Translate Sidebar"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  }
}
